{
  "name": "smartlake",
  "version": "2.0.0",
  "description": "SmartLake 2.0 — baliq ko'llari uchun real-time monitoring platformasi",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "emulators": "firebase emulators:start --only auth,firestore",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/rules\"",
    "test:all": "npm run test && npm run test:rules"
  },
  "dependencies": {
    "firebase": "^10.12.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "firebase-tools": "^15.22.4",
    "jsdom": "^29.1.1",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
