rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Firmware fayllar — faqat admin yuklaydi, qurilmalar o'qiydi
    match /firmware/{target}/{version}/{file} {
      allow read: if true;   // Gateway/Node yuklab olishi uchun
      allow write: if request.auth != null
        && request.auth.token.role in ['super', 'operator'];
    }

    // Boshqa fayllar — autentifikatsiya talab
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
