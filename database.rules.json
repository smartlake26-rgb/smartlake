{
  "rules": {
    "nodes": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$nodeId": { "history": { ".indexOn": ["ts"] } }
    },
    "gateway": { ".read": "auth != null", ".write": "auth != null" },
    "commands": { ".read": "auth != null", ".write": "auth != null", ".indexOn": ["ts"] },
    "requests": { ".read": "auth != null", ".write": "auth != null", ".indexOn": ["ts"] },
    "registry": { ".read": "auth != null", ".write": "auth != null" },
    "users": {
      ".read": "auth != null",
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    }
  }
}
