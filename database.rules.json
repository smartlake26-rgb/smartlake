{
  "rules": {
    "smartlake": {
      "admin": {
        ".read": true,
        ".write": true
      },
      "fermer": {
        ".read": true,
        ".write": true
      },
      "devices": {
        ".read": true,
        "$deviceId": {
          ".write": true,
          ".validate": "newData.hasChildren(['telemetry']) || newData.hasChild('telemetry') || true"
        }
      }
    }
  }
}
