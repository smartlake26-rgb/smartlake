{
  "rules": {

    "nodes": {
      ".read": "auth != null",
      "$chip": {
        ".write": "auth != null && (auth.token.email === 'device@smartlake.uz' || auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
        "history": { ".indexOn": ["ts"] }
      }
    },

    "gateway": {
      ".read": "auth != null",
      "$gw": {
        ".write": "auth != null && (auth.token.email === 'device@smartlake.uz' || auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())"
      }
    },

    "commands": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["ts"]
    },

    "users": {
      ".read": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "requests": {
      ".read": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
      ".indexOn": ["ts"],
      "$key": {
        ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())"
      }
    },

    "registry": {
      ".read": "auth != null",
      ".write": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())"
    },

    "admins": {
      ".read": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && auth.token.email === 'smartlake26@gmail.com'"
    },

    "audit": {
      ".read": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.email === 'smartlake26@gmail.com' || root.child('admins').child(auth.uid).exists())"
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
